{
  "manifest_version": 2,
  "name": "Universal Video Resizer",
  "version": "1.0",
  "description": "Resize iframes/videos per site via settings.",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "permissions": [
    "storage",
    "activeTab"
  ],
  "applications": {
    "gecko": {
      "id": "{12345678-1234-1234-1234-123456789abc}"
    }
  },
  "browser_action": {
  "default_popup": "options.html",
  "default_title": "Video Resizer Settings"
  },
  "icons": {
  "48": "icon.png"
}


}
