{
  "manifest_version": 2,
  "browser_specific_settings": {
    "gecko": {
      "id": "video-resizer@kcl.ac.uk",
      "data_collection_permissions": {
        "required": ["none"]
      }

    }
  },
  "name": "IFrame Video Resizer",
  "version": "1.0.1",
  "description": "Resize iframes/videos per site via settings, designed for uni websites, not tested extensively beyond",
  "homepage_url": "https://github.com/Grichere/videoResizingExtention",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "permissions": [
    "storage",
    "activeTab"
  ],
  "applications": {
    "gecko": {
      "id": "{12345678-1234-1234-1234-123456789abc}"
    }
  },
  "browser_action": {
  "default_popup": "options.html",
  "default_title": "Video Resizer Settings"
  },
  "icons": {
  "48": "icon.png"
  }



}
